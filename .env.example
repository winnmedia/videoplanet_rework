# Railway 환경변수 설정 예제
# 실제 배포 시 Railway 대시보드에서 설정

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings_railway

# Database (Railway PostgreSQL 플러그인으로 자동 설정됨)
# DATABASE_URL=postgresql://user:password@host:port/database

# Redis (Railway Redis 플러그인으로 자동 설정됨)  
# REDIS_URL=redis://localhost:6379

# SendGrid Email Settings
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=service@vlanet.net

# AWS S3 (선택사항)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=your-bucket-name

# Sentry (선택사항)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=production

# Frontend URL (CORS 설정용)
RAILWAY_FRONTEND_URL=https://your-frontend-domain.vercel.app